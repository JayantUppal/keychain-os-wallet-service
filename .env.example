# Copy to .env and adjust if needed.
DATABASE_URL=postgresql+psycopg2://wallet:wallet@localhost:5432/wallet
REDIS_URL=redis://localhost:6379/0

# Default order deduction amount, in paise (10000 = ₹100).
DEDUCT_AMOUNT_PAISE=10000

# Redis lock behaviour for concurrent deductions.
LOCK_TIMEOUT_SECONDS=10
LOCK_BLOCKING_TIMEOUT_SECONDS=5

# How long a cached balance stays valid.
BALANCE_CACHE_TTL_SECONDS=30

# Flask
FLASK_PORT=5000

# Observability
LOG_LEVEL=INFO
ENVIRONMENT=local
